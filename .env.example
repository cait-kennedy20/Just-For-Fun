ATLASSIAN_BASE_URL=https://your-company.atlassian.net
ATLASSIAN_EMAIL=your.name@company.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token
CONFLUENCE_PAGE_ID=123456789

# Option A (recommended): incoming webhook to your Slack Connect channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Option B: bot token + channel id (use this if you cannot use webhook)
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_CHANNEL_ID=C0123456789

# Ash endpoint that receives document update events
ASH_WEBHOOK_URL=https://ash.your-company.com/hooks/booking-feedback

# Poll interval for checking the Confluence page version
POLL_INTERVAL_SECONDS=60
